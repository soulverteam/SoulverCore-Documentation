{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/DateParsing"},"seeAlsoSections":[{"generated":true,"title":"String extensions for quick data parsing","identifiers":["doc:\/\/app.soulver.core\/documentation\/SoulverCore\/DataParsing"],"anchor":"String-extensions-for-quick-data-parsing"}],"sections":[],"kind":"article","metadata":{"roleHeading":"Article","modules":[{"name":"SoulverCore"}],"role":"article","title":"Natural language date parsing"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/soulvercore\/dateparsing"]}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Motivation","anchor":"Motivation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Natural language date input features can be found in apps like "},{"type":"reference","isActive":true,"identifier":"https:\/\/culturedcode.com\/things\/support\/articles\/9780167\/"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"https:\/\/flexibits.com\/fantastical-ios\/help\/adding"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"https:\/\/www.raycast.com\/extensions\/reminders"},{"type":"text","text":" and make the user experience better."}]},{"type":"heading","level":2,"text":"Usage","anchor":"Usage"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SoulverCore"},{"type":"text","text":" adds a single property "},{"type":"codeVoice","code":"dateValue"},{"type":"text","text":" to "},{"type":"codeVoice","code":"String"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["public extension String {","   var dateValue: Date?","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this property to extract the last natural language date found in the string. The "},{"type":"codeVoice","code":"dateValue"},{"type":"text","text":" will be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if there are no dates in the string."}]},{"type":"heading","anchor":"SoulverCore-vs-Foundations-DataDetector","text":"SoulverCore vs Foundation’s DataDetector","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Foundation framework includes NSDataDetector for detecting dates in strings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example:"}]},{"syntax":"swift","type":"codeListing","code":["let expression = \"March 5th, 2023\"","let types: NSTextCheckingResult.CheckingType = [.date ]","let detector = try! NSDataDetector(types: types.rawValue)","let match = detector.matches(in: expression, options: .init(rawValue: 0), range: NSRange(location: 0, length: expression.count)).first","let date = match?.date"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Compare this to SoulverCore:"}]},{"code":["let date = \"March 5th, 2023\".dateValue"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition to a much nicer API, SoulverCore also adds a number of additional features not supported by NSDataDetector."}]},{"type":"heading","anchor":"Supported-Features","text":"Supported Features","level":2},{"type":"heading","anchor":"Natural-language-calendar-math","text":"Natural language calendar math","level":4},{"type":"paragraph","inlineContent":[{"text":"Use natural language phrases like “3 weeks from tomorrow” and “march 12 + 4 weeks 3 days”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"SoulverCore supports a large range of different natural language date syntaxes. See the ","type":"text"},{"identifier":"https:\/\/documentation.soulver.app\/syntax-reference\/dates-and-times","type":"reference","isActive":true},{"text":" for more examples.","type":"text"}]},{"type":"heading","anchor":"Units--unit-shorthands","text":"Units & unit shorthands","level":4},{"type":"paragraph","inlineContent":[{"text":"SoulverCore interprets units of time as referring to a future date after the specified amount of time has passed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example ","type":"text"},{"type":"codeVoice","code":"2 weeks 2 days"},{"text":" will be interpreted as ","type":"text"},{"type":"codeVoice","code":"2 weeks and 2 days"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"from now"}]},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following time unit shorthands are also supported:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“1y” (1 year)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"“5mo” (5 months)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“3w” (3 weeks)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"“2d” (2 days)","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Shorthands can be combined together:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“12-9 9p” means the “12th of September at 9pm” (in a non-US locale)"}]}]}]},{"text":"Half-formed dates","type":"heading","anchor":"Half-formed-dates","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Examples:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“3\/12” (Dec 3, or March 12 in the US)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“12.2” (Feb 12 or Dec 2 in the US)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“9-5” (May 9 or Sep 5 in the US)"}]}]}]},{"text":"Day & month shorthands","type":"heading","anchor":"Day--month-shorthands","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Examples:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“Next mon” (next monday)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“tod” (today)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“apr3” (April 3)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“yes” (yesterday)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“tom” (tomorrow)"}]}]}]},{"text":"AM\/PM shorthands","type":"heading","anchor":"AMPM-shorthands","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Examples:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“3p” (3pm)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“5a” (5am)"}]}]}]},{"text":"Random words ignored","type":"heading","anchor":"Random-words-ignored","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"SoulverCore extracts the last date present in the given string, and ignores random words before and after it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, the following are valid inputs:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“Tom’s birthday party "},{"type":"strong","inlineContent":[{"text":"this sunday","type":"text"}]},{"type":"text","text":"”"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“Schedule the meeting for "},{"type":"strong","inlineContent":[{"text":"April 21st next year","type":"text"}]},{"type":"text","text":"”"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“"},{"type":"strong","inlineContent":[{"text":"June 5","type":"text"}]},{"type":"text","text":" the kids get off school”"}]}]}]},{"text":"Detailed information about the parsed date","type":"heading","anchor":"Detailed-information-about-the-parsed-date","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Datestamp\/DatestampType","isActive":true},{"type":"text","text":" enum contains detailed information about the kind of date detected and what date components were explicitly specified."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is how an example of how to get the formatting and components of the detected date:"}]},{"syntax":"swift","type":"codeListing","code":["var engineCustomization = EngineCustomization.standard","engineCustomization.featureFlags.seeksFutureDate = true","let calculator = Calculator(customization: engineCustomization)","","if let datestampType = calculator.dateFor(inputDateText)?.result.evaluationResult.datestampValue?.type {","    print(\"Date of type \\(datestampType)\")","}"]},{"text":"Performance","type":"heading","anchor":"Performance","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"SoulverCore is very efficient and can perform thousands of date-from-string extractions every second."}]},{"text":"Localizations","type":"heading","anchor":"Localizations","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition to English, SoulverCore is localized into German, French, Spanish, Russian & Simplified Chinese."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The user’s system locale will be used for date parsing, and date & time formats specific the particular region are taken into account."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Add a natural language date scheduling feature to your Mac or iOS calendar or reminders app"}],"hierarchy":{"paths":[["doc:\/\/app.soulver.core\/documentation\/SoulverCore"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"https://culturedcode.com/things/support/articles/9780167/":{"url":"https:\/\/culturedcode.com\/things\/support\/articles\/9780167\/","type":"link","identifier":"https:\/\/culturedcode.com\/things\/support\/articles\/9780167\/","title":"Things","titleInlineContent":[{"type":"text","text":"Things"}]},"https://flexibits.com/fantastical-ios/help/adding":{"url":"https:\/\/flexibits.com\/fantastical-ios\/help\/adding","type":"link","identifier":"https:\/\/flexibits.com\/fantastical-ios\/help\/adding","title":"Fantastical","titleInlineContent":[{"type":"text","text":"Fantastical"}]},"https://www.raycast.com/extensions/reminders":{"url":"https:\/\/www.raycast.com\/extensions\/reminders","type":"link","identifier":"https:\/\/www.raycast.com\/extensions\/reminders","title":"Raycast","titleInlineContent":[{"type":"text","text":"Raycast"}]},"doc://app.soulver.core/documentation/SoulverCore":{"url":"\/documentation\/soulvercore","role":"collection","title":"SoulverCore","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"A powerful natural language calculation engine"}]},"https://documentation.soulver.app/syntax-reference/dates-and-times":{"url":"https:\/\/documentation.soulver.app\/syntax-reference\/dates-and-times","type":"link","identifier":"https:\/\/documentation.soulver.app\/syntax-reference\/dates-and-times","title":"Soulver Documentation","titleInlineContent":[{"type":"text","text":"Soulver Documentation"}]},"doc://app.soulver.core/documentation/SoulverCore/DataParsing":{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/DataParsing","url":"\/documentation\/soulvercore\/dataparsing","title":"Data from string parsing","kind":"article","type":"topic","role":"article","abstract":[{"type":"text","text":"A declarative & type-safe approach to extracting various data types out of strings"}]},"doc://app.soulver.core/documentation/SoulverCore/Datestamp/DatestampType":{"url":"\/documentation\/soulvercore\/datestamp\/datestamptype","type":"topic","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Datestamp\/DatestampType","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatestampType"}],"role":"symbol","title":"Datestamp.DatestampType","abstract":[{"type":"text","text":"The types of datestamps supported by SoulverCore"}],"navigatorTitle":[{"kind":"identifier","text":"DatestampType"}],"kind":"symbol"}}}