{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/GettingStarted"},"hierarchy":{"paths":[["doc:\/\/app.soulver.core\/documentation\/SoulverCore"]]},"metadata":{"roleHeading":"Article","title":"Getting Started with SoulverCore","role":"article","modules":[{"name":"SoulverCore"}]},"abstract":[{"type":"text","text":"Create a calculator and customize calculation & result formatting"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/soulvercore\/gettingstarted"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/soulvercore\/gettingstarted"]}],"kind":"article","sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"To calculate the result of a single expression, use a ","type":"text"},{"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Calculator","isActive":true},{"type":"text","text":" object:"}]},{"type":"codeListing","code":["import SoulverCore","","let calculator = Calculator(customization: .standard)","let result = calculator.calculate(\"123 + 456\")","print(\"The answer is \\(result.stringValue)\") \/\/ prints 579"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"SoulverCore can perform all sorts of calculations, including unit conversions, date & calendar math, rate calculations, percentage phrase functions, time zone conversions, and much more. It also cleverly ignores “meaningless” words:"}]},{"type":"codeListing","syntax":"swift","code":["calculator.calculate(\"$10 for lunch + 15% tip\") \/\/ $11.50","calculator.calculate(\"65 kg in pounds\") \/\/ 143.3 lb","calculator.calculate(\"40 as % of 90\") \/\/ 44.44%","calculator.calculate(\"$150 is 25% on what\") \/\/ $120","calculator.calculate(\"$25\/hour * 14 hours of work\") \/\/ $350.00","calculator.calculate(\"January 30 2020 + 3 months 2 weeks 5 days\") \/\/ May 19, 2020","calculator.calculate(\"9:35am in New York to Japan\") \/\/ 10:35 pm","calculator.calculate(\"$25k over 10 years at 7.5%\") \/\/ $51,525.79 (compound interest)"]},{"text":"Variables","type":"heading","anchor":"Variables","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a "},{"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/VariableList","isActive":true},{"type":"text","text":" to set values for words or phrases in your expression:"}]},{"type":"codeListing","syntax":"swift","code":["let variableList = VariableList(variables:","    [","        Variable(name: \"a\", value: \"123\"),","        Variable(name: \"b\", value: \"456\"),","    ]",")","calculator.calculate(\"a + b\", with: variableList) \/\/ 579        "]},{"text":"Locale Settings","type":"heading","anchor":"Locale-Settings","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"SoulverCore respects the decimal separator and thousands separator of the system locale. Alternatively, you can convert the standard EngineCustomization to another locale:"}]},{"type":"codeListing","syntax":"swift","code":["let europeanLocale = Locale(identifier: \"en_DE\")","let localizedCustomization = EngineCustomization.standard.convertTo(locale: europeanLocale)","","let calculator = Calculator(customization: localizedCustomization)",""," \/\/\/ In Germany a comma is used as a decimal separator","calculator.calculate(\"1,2 + 3,4\") \/\/ 4,6"]},{"level":2,"anchor":"Output-Formatting","type":"heading","text":"Output Formatting"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a "},{"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/FormattingPreferences","isActive":true},{"type":"text","text":" to customize the way your result is formatted (how many decimal places to include, should the thousands separator be inserted, etc)."}]},{"type":"codeListing","code":["var formattingPreferences = FormattingPreferences()","formattingPreferences.dp = 2 \/\/ decimal places","calculator.formattingPreferences = formattingPreferences","","calculator.calculate(\"π\") \/\/ 3.14"],"syntax":"swift"},{"type":"heading","level":2,"text":"Live Real-World & Crypto-Currency Rates","anchor":"Live-Real-World--Crypto-Currency-Rates"},{"type":"paragraph","inlineContent":[{"text":"A standard ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization","type":"reference","isActive":true},{"text":" uses hard-coded rates for 190 real-world & crypto-currencies. You can (and should) provide SoulverCore with up-to-date rates by setting the ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization\/currencyRateProvider","type":"reference","isActive":true},{"text":" on your ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization","type":"reference","isActive":true},{"text":" to an object that conforms to ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/CurrencyRateProvider","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"SoulverCore includes one ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/CurrencyRateProvider","type":"reference","isActive":true},{"text":" you can use to fetch rates from the ","type":"text"},{"identifier":"https:\/\/www.ecb.europa.eu\/stats\/eurofxref\/","type":"reference","isActive":true},{"text":" for 33 popular fiat currencies.","type":"text"}]},{"type":"codeListing","code":["\/\/\/ This is a currency rate provider that fetches 33 popular fiat currencies from the European Central Bank, no API key required","let ecbCurrencyRateProvider = ECBCurrencyRateProvider()","","\/\/\/ Create a customization with this rate provider","var customizationWithLiveCurrencyRates = EngineCustomization.standard","customizationWithLiveCurrencyRates.currencyRateProvider = ecbCurrencyRateProvider","","\/\/\/ Create a calculator that uses this customization","let calculator = Calculator(customization: customizationWithLiveCurrencyRates)","","\/\/\/ Update to the latest rates...","ecbCurrencyRateProvider.updateRates { success in","    if success {","        \/\/ The standard customization will now have access to the latest currency rates","        let result = calculator.calculate(\"10 USD in EUR\")","        print(result.stringValue)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can create your own object that conforms to ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/CurrencyRateProvider","type":"reference","isActive":true},{"text":" to provide rates for the currency codes you support. The ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/CurrencyRateProvider","type":"reference","isActive":true},{"text":" protocol has a single method that returns the amount of a given currency that 1.0 USD can buy:","type":"text"}]},{"type":"codeListing","code":["func rateFor(request: CurrencyRateRequest) -> Decimal? {","","    let currencyCode = request.currencyCode \/\/ EUR, GBP, BTC, etc","","    \/\/\/ - Return an up-to-date rate in the form of how much 1 USD can purchase of the requested currency (i.e 1 USD = x EUR?)","    \/\/\/ - If your rates are in terms of how much USD the requested currency can purchase (i.e 1 EUR = x USD?), remember to take the inverse by dividing 1 by your rate","            ","    return <# Currency Rate #>","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Rates are only requested from a ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/CurrencyRateProvider","type":"reference","isActive":true},{"text":" at evaluation-time, so you don’t need to recreate or ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Calculator","type":"reference","isActive":true},{"text":" with a new ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization","type":"reference","isActive":true},{"text":" when your currency rate data source is updated. However you must reevaluate your line or expression: the latest rates for any currencies used will be fetched from your provider, if necessary.","type":"text"}]},{"type":"heading","level":2,"text":"Custom Units","anchor":"Custom-Units"},{"type":"paragraph","inlineContent":[{"text":"You can add custom units to an ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization","type":"reference","isActive":true},{"text":" object required by the initializer on ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Calculator","type":"reference","isActive":true}]},{"type":"codeListing","code":["\/\/\/ A good omakase EngineCustomization (the same used by Soulver.app)","var customization: EngineCustomization = .standard","","\/\/\/ Set an array of custom units defined in terms of an existing unit in SoulverCore","customization.customUnits = [","    CustomUnit(name: \"parrots\", definition: 15, equivalentUnit: .centimeters),","    CustomUnit(name: \"python\", definition: 570, equivalentUnit: .centimeters)","]","","\/\/\/ Create a Calculator using this customization","let calculator = Calculator(customization: customization)","","\/\/\/ python and parrots are now recognized as units","calculator.calculate(\"1 python in parrots\") \/\/ 38 parrots"],"syntax":"swift"},{"level":2,"anchor":"Custom-Functions","type":"heading","text":"Custom Functions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The syntax of a function in SoulverCore is flexible. We support traditional C-style “func(x)” functions, Swift-style “calculate(withParameter: x)” functions, or even natural phrases like “calculate x”."}]},{"type":"paragraph","inlineContent":[{"text":"You can add custom functions objects to the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization","type":"reference"},{"text":" required by the initializer on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Calculator","type":"reference"},{"text":". Here is an example of a custom function that takes 1 off a given number:","type":"text"}]},{"type":"codeListing","code":["","\/\/\/ Get the default Engine Customization","var customization: EngineCustomization = .standard","","\/\/\/ A prototype expression is an example of what the user will type to invoke your function","\/\/\/ The following function will trigger for any phrase with the form 'number before x', where x is some number","","customization.customFunctions = [CustomFunction(prototypeExpression: \"number before 9\", handler: { parameters in","    ","    guard let parameterDecimalValue = parameters[0].decimalValue else {","        return EvaluationResult.none","    }","    ","    return .decimal(parameterDecimalValue - 1.0)","    ","})]","","let calculator = Calculator(customization: customization)","let result = calculator.calculate(\"number before 35\")","","print(result.stringValue) \/\/ prints '34'"],"syntax":"swift"},{"type":"heading","level":2,"text":"Localizations","anchor":"Localizations"},{"type":"paragraph","inlineContent":[{"text":"In addition to English, SoulverCore is fully localized into German, Russian, French, Spanish & simplified Chinese.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The various number & date formats of these various locales are also fully supported.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Also note that non-English languages are ","type":"text"},{"inlineContent":[{"text":"additive","type":"text"}],"type":"emphasis"},{"text":", meaning that, for instance, a German user would be able to use both English & German syntaxes.","type":"text"}]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://app.soulver.core/documentation/SoulverCore/EngineCustomization/currencyRateProvider":{"url":"\/documentation\/soulvercore\/enginecustomization\/currencyrateprovider","type":"topic","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization\/currencyRateProvider","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"currencyRateProvider","kind":"identifier"},{"text":": ","kind":"text"},{"text":"CurrencyRateProvider","preciseIdentifier":"s:11SoulverCore20CurrencyRateProviderP","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"role":"symbol","title":"currencyRateProvider","abstract":[{"type":"text","text":"Provide an object that conforms to "},{"type":"codeVoice","code":"CurrencyRateProvider"},{"type":"text","text":" to enable live currency rates in calculations"}],"kind":"symbol"},"doc://app.soulver.core/documentation/SoulverCore":{"url":"\/documentation\/soulvercore","role":"collection","title":"SoulverCore","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"A powerful natural language calculation engine"}]},"doc://app.soulver.core/documentation/SoulverCore/VariableList":{"url":"\/documentation\/soulvercore\/variablelist","type":"topic","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/VariableList","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"VariableList"}],"role":"symbol","title":"VariableList","abstract":[{"type":"text","text":"A list of variables (single words or phrases) and their values"}],"navigatorTitle":[{"kind":"identifier","text":"VariableList"}],"kind":"symbol"},"doc://app.soulver.core/documentation/SoulverCore/FormattingPreferences":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FormattingPreferences"}],"kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"FormattingPreferences"}],"url":"\/documentation\/soulvercore\/formattingpreferences","title":"FormattingPreferences","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/FormattingPreferences","abstract":[{"text":"A configuration object used to specify how you want SoulverCore to format results","type":"text"}]},"doc://app.soulver.core/documentation/SoulverCore/CurrencyRateProvider":{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/CurrencyRateProvider","url":"\/documentation\/soulvercore\/currencyrateprovider","title":"CurrencyRateProvider","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CurrencyRateProvider","kind":"identifier"}],"navigatorTitle":[{"text":"CurrencyRateProvider","kind":"identifier"}],"abstract":[{"type":"text","text":"CurrencyRateProvider is an object that provides currency rates to be used in unit calculations"}]},"https://www.ecb.europa.eu/stats/eurofxref/":{"url":"https:\/\/www.ecb.europa.eu\/stats\/eurofxref\/","type":"link","identifier":"https:\/\/www.ecb.europa.eu\/stats\/eurofxref\/","title":"European Central Bank","titleInlineContent":[{"text":"European Central Bank","type":"text"}]},"doc://app.soulver.core/documentation/SoulverCore/EngineCustomization":{"type":"topic","navigatorTitle":[{"text":"EngineCustomization","kind":"identifier"}],"title":"EngineCustomization","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"EngineCustomization"}],"url":"\/documentation\/soulvercore\/enginecustomization","abstract":[{"text":"A key SoulverCore model object used to customize how you want SoulverCore to interpret expressions","type":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization"},"doc://app.soulver.core/documentation/SoulverCore/Calculator":{"url":"\/documentation\/soulvercore\/calculator","type":"topic","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Calculator","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Calculator"}],"role":"symbol","title":"Calculator","abstract":[{"text":"Evaluate natural language mathematical expressions","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"Calculator"}],"kind":"symbol"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","path":"\/identifier\/interfaceLanguage","value":"occ"},{"op":"add","path":"\/topicSections","value":null},{"op":"add","value":null,"path":"\/seeAlsoSections"}]}]}