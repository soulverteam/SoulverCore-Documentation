{"abstract":[{"text":"Enable this flag to indicate that SoulverCore should attempt to extract a date from the users’ expression, even in cases that would normally not produce a date","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","externalID":"s:11SoulverCore18DateParsingOptionsV05seeksC0Sbvp","title":"seeksDate","roleHeading":"Instance Property","symbolKind":"property","modules":[{"name":"SoulverCore"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"seeksDate","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/DateParsingOptions\/seeksDate"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"seeksDate","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"For example, unit expressions of time will resolve to a date (i.e ‘20 minutes’ will be equivalent to the expression ‘20 minutes from now’)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Additional shorthand aliases for time units will be added, like “d” for days, and “w” for weeks"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially formatted dates like “15\/3” (ordinarily interpreted as “15 ÷ 3”) will be assumed to refer to a date"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Off by default"}]}]}]}]}],"hierarchy":{"paths":[["doc:\/\/app.soulver.core\/documentation\/Soulver