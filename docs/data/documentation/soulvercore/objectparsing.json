{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser"},{"text":" lets you parse a natural language string into a ready-to-use Swift object (or graph of objects) in a single call. It handles the tokenization, type recognition, and data extraction automatically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Unlike the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/DataPoint"},{"text":"-based ","type":"text"},{"type":"codeVoice","code":"find"},{"text":" API (which extracts individual data points from strings), ObjectParser creates complete model objects — with all their properties populated from the data in the string.","type":"text"}]},{"level":2,"anchor":"Quick-start","type":"heading","text":"Quick start"},{"type":"paragraph","inlineContent":[{"text":"The easiest way to parse objects is with the ","type":"text"},{"type":"codeVoice","code":"parseObject()"},{"text":" string extension, combined with types conforming to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ParsableObject"},{"text":":","type":"text"}]},{"type":"codeListing","code":["import SoulverCore","","struct SalesRecord: ParsableObject {","    let quantity: Int","    let date: Date","","    init(from parser: ObjectParser) throws {","        self.quantity = try parser.scan(.number)","        self.date = try parser.scan(.date)","    }","}","","let record: SalesRecord = try \"We sold 130 copies yesterday\".parseObject()","\/\/ record.quantity → 130","\/\/ record.date → yesterday's date"],"syntax":"swift"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The companion "},{"type":"reference","identifier":"https:\/\/github.com\/soulverteam\/ObjectParsing","isActive":true},{"type":"text","text":" package provides a "},{"type":"codeVoice","code":"@ParsableObject"},{"type":"text","text":" macro that generates the "},{"type":"codeVoice","code":"init(from:)"},{"type":"text","text":" for you, and includes ready-to-use higher-order primitive types (flights, places, currencies, etc)."}]}]},{"level":2,"anchor":"Using-ObjectParser-directly","type":"heading","text":"Using ObjectParser directly"},{"type":"paragraph","inlineContent":[{"text":"For more control, create an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser"},{"text":" instance yourself:","type":"text"}]},{"type":"codeListing","code":["let parser = ObjectParser(\"QF 123 tomorrow\")","","let flight: Flight = try parser.parse(Flight.self)","let date: Date = try parser.scan(.date)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Creating the parser directly is useful when:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You want to attempt multiple parses on the same tokenized string (using ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser\/reset()","type":"reference","isActive":true},{"text":" between attempts)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You need to check the structure of the expression before parsing","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You want to provide a custom ","type":"text"},{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/EngineCustomization","type":"reference","isActive":true}]}]}]},{"level":2,"anchor":"Scanning-data-points","type":"heading","text":"Scanning data points"},{"type":"paragraph","inlineContent":[{"text":"Inside a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ParsableObject"},{"text":" initializer, you use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser\/scan(_:)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"scanIfPresent"},{"text":" to extract individual data points from the expression:","type":"text"}]},{"type":"codeListing","code":["struct Pace: ParsableObject {","    let distanceTravelled: Decimal","    let time: TimeInterval","","    init(from parser: ObjectParser) throws {","        self.time = try parser.scan(.timespan).timeIntervalValue","        self.distanceTravelled = try parser.scan(.number)","    }","","    static var orderingStrategy: OrderingStrategy { .unordered }","}","","let pace: Pace = try \"I ran 3 km in 12.5 minutes\".parseObject()","\/\/ pace.distanceTravelled → 3","\/\/ pace.time → 750.0 (seconds)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"scan"},{"text":" throws if the data type isn’t found. ","type":"text"},{"type":"codeVoice","code":"scanIfPresent"},{"text":" returns nil instead.","type":"text"}]},{"level":2,"anchor":"Nested-objects","type":"heading","text":"Nested objects"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"parse"},{"text":" also handles nested ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ParsableObject"},{"text":" types, making object composition straightforward:","type":"text"}]},{"type":"codeListing","code":["struct FlightOnDate: ParsableObject {","    let flight: Flight","    let date: Date","","    init(from parser: ObjectParser) throws {","        self.flight = try parser.parse(Flight.self)","        self.date = try parser.scan(.date)","    }","}","","let query: FlightOnDate = try \"QF123 tomorrow\".parseObject()"],"syntax":"swift"},{"level":2,"anchor":"Ordered-vs-unordered-parsing","type":"heading","text":"Ordered vs unordered parsing"},{"type":"paragraph","inlineContent":[{"text":"By default, properties are scanned in declaration order (the parser cursor advances forward through the string). Set ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/OrderingStrategy\/unordered"},{"text":" to allow properties to appear in any order:","type":"text"}]},{"type":"codeListing","code":["struct Meeting: ParsableObject {","    let date: Date","    let attendees: Int","","    init(from parser: ObjectParser) throws {","        self.date = try parser.scan(.date)","        self.attendees = try parser.scan(.number)","    }","","    static var orderingStrategy: OrderingStrategy { .unordered }","}","","\/\/ Both of these work:","let m1: Meeting = try \"March 15 with 5 people\".parseObject()","let m2: Meeting = try \"5 people on March 15\".parseObject()"],"syntax":"swift"},{"level":2,"anchor":"Keywords","type":"heading","text":"Keywords"},{"type":"paragraph","inlineContent":[{"text":"To parse custom enum types from strings, conform them to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Keyword"},{"text":" and declare them as keyword types when creating the parser. Keywords are matched case-insensitively:","type":"text"}]},{"type":"codeListing","code":["enum BreakfastItem: String, Keyword {","    case waffles","    case eggs","","    var aliases: [String] {","        switch self {","        case .waffles: return [\"waffle\"]","        case .eggs: return [\"egg\"]","        }","    }","}","","struct BreakfastOrder: ParsableObject {","    let quantity: Int","    let item: BreakfastItem","","    init(from parser: ObjectParser) throws {","        self.quantity = try parser.scan(.number)","        self.item = try parser.scanKeyword(ofType: BreakfastItem.self)","    }","","    static var keywordTypes: KeywordTypeList { [BreakfastItem.self] }","}","","let order: BreakfastOrder = try \"2 waffles\".parseObject()"],"syntax":"swift"},{"type":"aside","name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keyword types must be declared in "},{"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ParsableObject\/keywordTypes","isActive":true},{"type":"text","text":" (or passed to the "},{"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser","isActive":true},{"type":"text","text":" initializer) so the parser can recognize them during tokenization."}]}]},{"level":2,"anchor":"Checking-expression-structure","type":"heading","text":"Checking expression structure"},{"type":"paragraph","inlineContent":[{"text":"You can inspect the expression before attempting a full parse:","type":"text"}]},{"type":"codeListing","code":["let parser = ObjectParser(\"time in Sydney\")","","\/\/ Does this expression have the same structure as another?","parser.matchesStructure(of: \"time in Los Angeles\") \/\/ true","parser.matchesStructure(of: \"flights to London\")   \/\/ false","","\/\/ Are particular words present?","try parser.ensurePresent(words: [\"time\"]) \/\/ succeeds","","\/\/ Does the expression contain a particular token type?","parser.containsType(tokenType: .date)    \/\/ false","parser.containsType(tokenType: .place)   \/\/ true"],"syntax":"swift"},{"level":2,"anchor":"Attempting-multiple-parses","type":"heading","text":"Attempting multiple parses"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser\/reset()"},{"text":" to rewind the parser’s cursor and try parsing a different type from the same tokenized expression:","type":"text"}]},{"type":"codeListing","code":["let parser = ObjectParser(\"QF 33 to London\", keywordTypes: [Airline.self, TravelDirection.self])","","if let flight: FlightLookup = try? parser.parse(FlightLookup.self) {","    \/\/ Got a full flight lookup","} else {","    parser.reset()","    if let route: RouteLookup = try? parser.parse(RouteLookup.self) {","        \/\/ Got a route lookup instead","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This avoids re-tokenizing the string when you want to attempt multiple types against the same input.","type":"text"}]},{"level":2,"anchor":"Performing-replacements","type":"heading","text":"Performing replacements"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser"},{"text":" can also generate new strings by replacing matched data types:","type":"text"}]},{"type":"codeListing","code":["let parser = ObjectParser(\"I scored 85 and then 92\")","","\/\/ Replace the first number","let result = parser.replacingFirst(.number) { value in","    return \"\\(value + 10)\"","}","\/\/ \"I scored 95 and then 92\"","","\/\/ Replace all numbers","let result2 = parser.replacingAll(.number) { value in","    return \"\\(value + 10)\"","}","\/\/ \"I scored 95 and then 102\""],"syntax":"swift"},{"level":2,"anchor":"Error-handling","type":"heading","text":"Error handling"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser"},{"text":" throws ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser\/ScanningError"},{"text":" values that include the type being parsed and the original expression, making debugging straightforward:","type":"text"}]},{"type":"codeListing","code":["do {","    let _: Flight = try \"not a flight\".parseObject()","} catch {","    print(error.localizedDescription)","    \/\/ \"Failed to parse Flight from expression: 'not a flight'\"","}"],"syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/soulvercore\/objectparsing"]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/app.soulver.core\/documentation\/SoulverCore"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"SoulverCore"}],"roleHeading":"Article","role":"article","title":"Parsing objects from natural language"},"identifier":{"url":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParsing","interfaceLanguage":"swift"},"abstract":[{"text":"Transform natural language strings into strongly-typed Swift objects with a single call","type":"text"}],"seeAlsoSections":[{"title":"Parsing objects from natural language","identifiers":["doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ParsableObject","doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser","doc:\/\/app.soulver.core\/documentation\/SoulverCore\/Keyword","doc:\/\/app.soulver.core\/documentation\/SoulverCore\/KeywordTypeList","doc:\/\/app.soulver.core\/documentation\/SoulverCore\/OrderingStrategy"],"anchor":"Parsing-objects-from-natural-language","generated":true}],"references":{"doc://app.soulver.core/documentation/SoulverCore/ParsableObject":{"abstract":[{"type":"text","text":"Adopt by an object that can be initialized from a string representation"}],"kind":"symbol","identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ParsableObject","navigatorTitle":[{"kind":"identifier","text":"ParsableObject"}],"type":"topic","role":"symbol","url":"\/documentation\/soulvercore\/parsableobject","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ParsableObject"}],"title":"ParsableObject"},"doc://app.soulver.core/documentation/SoulverCore/ObjectParser":{"identifier":"doc:\/\/app.soulver.core\/documentation\/SoulverCore\/ObjectParser","url":"\/documentation\/soulvercore\/objectparser","t